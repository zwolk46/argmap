# argmap — local development env vars.
# Copy this file to `.env.local` and fill in values from your Supabase
# project's Settings → API page. Production deployments do NOT use this
# file — Vercel's Marketplace Supabase integration auto-provisions the
# same names. See SETUP.md.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
